---
import Default from "@astrojs/starlight/components/MobileMenuFooter.astro";
import type { Props } from "@astrojs/starlight/props";
import { Icon } from "@astrojs/starlight/components";
---

<div class="mobile-footer sl-flex">
  <div class="community-links sl-flex">
    <a href="https://github.com/AREA44/astro-supernova" class="sl-flex">
      <Icon name="github" /> GitHub
    </a>
    <a href="https://astro.build/chat" class="sl-flex">
      <Icon name="discord" /> Discord
    </a>
  </div>
  <Default {...Astro.props}><slot /></Default>
</div>

<style>
  .mobile-footer {
    flex-direction: column;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sl-color-hairline);
  }
  .community-links {
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    font-size: var(--sl-text-sm);
  }
  .community-links a {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    text-decoration: none;
    color: var(--sl-color-gray-3);
  }
  .community-links a:hover {
    color: var(--sl-color-white);
  }
</style>
